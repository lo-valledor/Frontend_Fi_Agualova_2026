# ============================================
# Dockerfile UAT/Development Environment
# ============================================
# Este Dockerfile es para el entorno de UAT (User Acceptance Testing)
# que funciona igual que producción pero con tema naranja

# ============================================
# Stage 1: Install dependencies
# ============================================
FROM node:22-alpine AS development-dependencies-env

RUN corepack enable

COPY package.json pnpm-lock.yaml /app/
WORKDIR /app

RUN pnpm install --frozen-lockfile

# ============================================
# Stage 2: Build de la aplicación para UAT
# ============================================
FROM node:22-alpine AS development-build-env

RUN corepack enable

WORKDIR /app

COPY --from=development-dependencies-env /app/node_modules /app/node_modules
COPY . /app/

# Variables de entorno para UAT/Development
ARG VITE_API_URL
ARG NODE_ENV=development
ARG VITE_APP_ENV=development
ENV VITE_API_URL=$VITE_API_URL
ENV NODE_ENV=$NODE_ENV
ENV VITE_APP_ENV=$VITE_APP_ENV

# Build para UAT
RUN pnpm run build

# ============================================
# Stage 3: Nginx para UAT (igual que producción)
# ============================================
FROM nginx:alpine AS development-nginx

# Metadatos
LABEL maintainer="Enerlova Team"
LABEL description="Frontend Enerlova - UAT/Development"
LABEL environment="development"

# Instalar curl para healthchecks
RUN apk add --no-cache curl

# Copiar archivos buildados
COPY --from=development-build-env /app/build/client /usr/share/nginx/html

# Copiar configuración de nginx para desarrollo
COPY nginx.dev.conf /etc/nginx/nginx.conf

# Crear directorios necesarios y configurar permisos
RUN mkdir -p /var/cache/nginx /var/log/nginx /var/run && \
    chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    chown -R nginx:nginx /var/run && \
    chmod -R 755 /usr/share/nginx/html && \
    touch /var/run/nginx.pid && \
    chown nginx:nginx /var/run/nginx.pid

# Exponer puerto 80 (igual que producción)
EXPOSE 80

# Healthcheck
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost/ || exit 1

# Usuario no-root
USER nginx

# Comando de inicio
CMD ["nginx", "-g", "daemon off;"]
