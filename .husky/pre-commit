#!/bin/sh

# Git hook para generar documentación automáticamente antes de commit
# Se ejecuta antes de cada commit

echo "🤖 Generando documentación automática..."

# Verificar si hay archivos modificados que requieran regenerar docs
MODIFIED_FILES=$(git diff --cached --name-only)

# Archivos que requieren regeneración de documentación
REQUIRES_DOCS_REGEN=false

# Verificar cambios en servicios, componentes o tipos
if echo "$MODIFIED_FILES" | grep -E "(app/services/|app/components/|app/types/|app/hooks/)" > /dev/null; then
    REQUIRES_DOCS_REGEN=true
fi

if [ "$REQUIRES_DOCS_REGEN" = true ]; then
    echo "📝 Archivos modificados detectados que requieren actualización de docs"
    
    # Generar documentación
    npm run docs:generate
    
    # Verificar si se generaron cambios en la documentación
    if [ -n "$(git status --porcelain docs/generated/)" ]; then
        echo "✅ Documentación actualizada automáticamente"
        git add docs/generated/
        echo "📁 Archivos de documentación añadidos al commit"
    else
        echo "ℹ️  No se requirieron cambios en la documentación"
    fi
else
    echo "ℹ️  No se detectaron cambios que requieran actualización de documentación"
fi

echo "🎉 Hook pre-commit completado"