{
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "exclude": [
    "app/routes/dashboard/reportes/components/**/*",
    "app/services/reportes/**/*",
    "app/components/reportes/resumen-facturacion/**/*",
    "app/components/reportes/consultar-contrato/contrato/**/*",
    "app/hooks/use-operaciones.ts",
    "app/hooks/operaciones/use-calculo-facturacion-flow.ts",
    "app/components/administracion/acometida/**/*.test.tsx"
  ],
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["node", "vite/client"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
