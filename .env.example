# ==================================================
# 🔧 VARIABLES DE ENTORNO - FRONTEND ENERLOVA
# ==================================================

# Entorno de la aplicación
# Valores: 'development' | 'production'
# Esto controla la tematización visual de la aplicación
VITE_APP_ENV=development

# URL base de la API backend
VITE_API_URL=http://192.168.1.139:8081/Enerlova

# Node environment (usado por herramientas de build)
NODE_ENV=development

# ==================================================
# 📝 NOTAS:
# ==================================================
# 
# 1. VITE_APP_ENV controla:
#    - Paleta de colores (azul para prod, naranja para dev)
#    - Indicador visual de entorno
#    - Comportamiento de la aplicación
#
# 2. Para desarrollo local:
#    VITE_APP_ENV=development pnpm run dev
#
# 3. Para producción:
#    VITE_APP_ENV=production pnpm run build
#
# 4. Docker compose ya tiene estas variables configuradas:
#    - docker-compose.dev.yml: VITE_APP_ENV=development
#    - docker-compose.prod.yml: VITE_APP_ENV=production
#
# ==================================================
