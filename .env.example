# ==========================================
# Agualova Frontend - Environment Variables
# ==========================================
# ⚠️  IMPORTANTE:
# - VITE_API_URL se configura en GitHub Secrets (no en este archivo)
# - Este archivo es solo para desarrollo local si lo necesitas
# - El CI/CD obtiene los valores de GitHub Actions Secrets

# Backend API Configuration (para desarrollo local)
VITE_API_URL=http://localhost:8081/Agualova

# Application Environment
VITE_APP_ENV=production
VITE_ENV_MODE=production

# Puerto de acceso
# Contenedor (nginx) escucha en puerto 80
# Host expone puerto 8080 (sin necesidad de permisos root)
# Acceso: http://192.168.1.197:8080
