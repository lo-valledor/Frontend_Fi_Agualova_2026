{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Enerlova Frontend Documentation",
  "entryPoints": [
    "./app/services/*.ts",
    "./app/hooks/*.ts",
    "./app/lib/*.ts",
    "./app/types/*.ts"
  ],
  "entryPointStrategy": "expand",
  "out": "./docs/typedoc",
  "theme": "default",
  "readme": "./README.md",
  "includeVersion": true,
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": false,
  "disableSources": false,
  "sourceLinkTemplate": "https://github.com/lo-valledor/front-respaldo/blob/{gitRevision}/{path}#L{line}",
  "gitRevision": "develop",
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "**/node_modules/**"
  ],
  "plugin": ["typedoc-plugin-markdown"],
  "categoryOrder": ["Services", "Hooks", "Types", "Utilities", "*"],
  "sort": ["source-order"],
  "kindSortOrder": [
    "Document",
    "Project",
    "Module",
    "Namespace",
    "Enum",
    "EnumMember",
    "Class",
    "Interface",
    "TypeAlias",
    "Constructor",
    "Property",
    "Variable",
    "Function",
    "Accessor",
    "Method",
    "Parameter",
    "TypeParameter",
    "TypeLiteral",
    "CallSignature",
    "ConstructorSignature",
    "IndexSignature",
    "GetSignature",
    "SetSignature"
  ],
  "searchInComments": true,
  "cleanOutputDir": true,
  "titleLink": "https://github.com/lo-valledor/front-respaldo",
  "navigationLinks": {
    "GitHub": "https://github.com/lo-valledor/front-respaldo",
    "Documentation": "./docs/README.md"
  },
  "sidebarLinks": {
    "Architecture": "./ARCHITECTURE.md",
    "Deployment": "./DEPLOY-README.md"
  },
  "treatWarningsAsErrors": false,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  }
}
